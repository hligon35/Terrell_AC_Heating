# Local environment toggles
# Set to 1 to route store and uploads through the Cloudflare Worker
USE_CLOUDFLARE=0

# When USE_CLOUDFLARE=1 point to your published worker URL (no trailing slash)
# Example: https://terrellach.hligon.workers.dev
WORKER_API_BASE=https://terrellach.hligon.workers.dev

# Next.js runtime port (dev)
NEXT_PUBLIC_PORT=3000

# Admin credentials for local dev (used by /api/auth/login)
ADMIN_USER=admin
ADMIN_PASS=changeme
PORT=3000
